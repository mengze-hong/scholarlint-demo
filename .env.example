# ─────────────────────────────────────────────────────────────
# .env.example  —  template only. NEVER commit a real .env.
#
# Copy this file to `.env` on the production host (do not commit
# the copy; .env is in .gitignore) and fill in real values via SSH.
# Leaving JWT_SECRET / ADMIN_KEY blank is correct — the app will
# generate them on first start under data/.jwt_secret and data/.admin_key.
# ─────────────────────────────────────────────────────────────

# Production switches (DEPLOY_SAFE.md)
APP_ENV=production
PAYMENT_SANDBOX=false

# LLM gateway (LiteLLM-compatible). Use the internal address when the
# host is on the same VPC; do NOT route through public LLM providers.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-5.2

# Auth + admin: leave blank in production so the app generates and
# persists these as 32-byte / 16-byte random tokens under data/.
# Setting them explicitly is only useful for ephemeral test boxes.
JWT_SECRET=
ADMIN_KEY=

# Alipay — only set when accepting real payments. Until then,
# PAYMENT_SANDBOX=true (which contradicts production; keep these empty
# until you actually wire payment).
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# LLM rate-limit knobs (defaults are fine for MVP)
LLM_RATE_PER_IP=30
LLM_RATE_WINDOW=3600
LLM_GLOBAL_HOURLY_CAP=500

# Crossref polite-pool address; use a real mailbox you control.
CROSSREF_EMAIL=ops@your-domain.example
